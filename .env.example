# ── rail0-hyper environment variables ────────────────────────────────────────
#
# Copy to .env and fill in your values. Never commit .env to git.

# ── Database ──────────────────────────────────────────────────────────────────
# Used by both Envio and the Hono API server / reconciler.
#
# Local (Envio internal DB, started automatically by `envio dev`):
ENVIO_PG_HOST=localhost
ENVIO_PG_PORT=5433
ENVIO_PG_USER=postgres
ENVIO_PG_PASSWORD=testing
ENVIO_PG_DATABASE=envio-dev
# Neon (cloud) — uncomment and fill in, comment out the local block above:
# ENVIO_PG_HOST=<host>.neon.tech
# ENVIO_PG_PORT=5432
# ENVIO_PG_USER=<user>
# ENVIO_PG_PASSWORD=<password>
# ENVIO_PG_DATABASE=<database>
# ENVIO_PG_SSL_MODE=require

# Base URL of the rail0-api instance this indexer notifies.
RAIL0_API_URL=http://localhost:3000

# 32-byte (64 hex char) shared secret for HMAC request signing.
# Must match the value configured in rail0-api.
RAIL0_API_HMAC_SECRET=

# Port for the standalone Hono API server (default: 3001).
# API_PORT=3001

# NODE_ENV: development | staging | production
# Controls which chain list is used (see src/chains.ts and bin/gen-config).
NODE_ENV=development

# Disable Envio's Hasura integration — we use a custom Hono API server instead.
ENVIO_HASURA=false
