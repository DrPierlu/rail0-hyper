# ── rail0-hyper environment variables ────────────────────────────────────────
#
# Copy to .env and fill in your values. Never commit .env to git.

# PostgreSQL connection string for Envio's index DB.
# Envio will create / migrate the schema automatically.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/rail0_hyper

# Base URL of the rail0-api instance this indexer notifies.
RAIL0_API_URL=http://localhost:3000

# 32-byte (64 hex char) shared secret for HMAC request signing.
# Must match the value configured in rail0-api.
RAIL0_API_HMAC_SECRET=

# Port for the standalone Hono API server (default: 3001).
# API_PORT=3001

# NODE_ENV: development | staging | production
# Controls which chain list is used (see src/chains.ts and bin/gen-config).
NODE_ENV=development
