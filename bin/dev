#!/usr/bin/env bash
# bin/dev — Start rail0-hyper in development mode.
#
# Steps:
#   1. Check prerequisites
#   2. Install dependencies if needed
#   3. Generate config.yaml from rail0-api (fallback: start_block 0)
#   4. Run Envio codegen if generated/ is absent
#   5. Start Envio indexer + Hono API server in parallel

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

# ── Load .env if present ──────────────────────────────────────────────────────

if [[ -f ".env" ]]; then
  set -o allexport
  # shellcheck source=/dev/null
  source .env
  set +o allexport
fi

# ── Prerequisites ─────────────────────────────────────────────────────────────

command -v node >/dev/null 2>&1 || { echo "❌  node not found"; exit 1; }
command -v pnpm >/dev/null 2>&1 || { echo "❌  pnpm not found"; exit 1; }

# ── Dependencies ──────────────────────────────────────────────────────────────
# pnpm install at root links the workspace packages.
# generated/ has its own node_modules that must also be installed.

if [[ ! -d "node_modules" ]]; then
  echo "📦  Installing dependencies…"
  pnpm install
fi

if [[ -d "generated" ]]; then
  if [[ ! -d "generated/node_modules" ]]; then
    echo "📦  Installing generated/ dependencies…"
    # --ignore-scripts avoids spurious husky/prepare hook failures from transitive deps
    (cd generated && npm install --ignore-scripts)
  fi
  # ReScript dependencies (e.g. rescript-envsafe) ship only source .res files —
  # they must be compiled before the indexer can start.
  if [[ ! -f "generated/node_modules/rescript-envsafe/src/EnvSafe.res.js" ]]; then
    echo "🔨  Compiling ReScript dependencies…"
    (cd generated && npm run build)
  fi
fi

# ── Envio codegen ─────────────────────────────────────────────────────────────
# Only needed when schema.graphql or the event list in config.yaml changes.
# Re-run manually with: pnpm codegen

if [[ ! -d "generated" ]]; then
  echo "🔧  Running Envio codegen…"
  pnpm envio codegen
fi

# ── Select config file for this environment ───────────────────────────────────

NODE_ENV="${NODE_ENV:-development}"
if [[ "$NODE_ENV" == "staging" ]]; then
  ENVIO_CONFIG="config.staging.yaml"
elif [[ "$NODE_ENV" == "production" ]]; then
  ENVIO_CONFIG="config.production.yaml"
else
  ENVIO_CONFIG="config.yaml"
fi

# ── Patch start_block values from rail0-api ───────────────────────────────────
# Falls back to existing values if rail0-api is unreachable.

echo "⚙️   Patching start_block in ${ENVIO_CONFIG}…"
NODE_ENV="$NODE_ENV" node "$ROOT/bin/gen-config.mjs"

# ── Start services ────────────────────────────────────────────────────────────

echo ""
echo "🚀  Starting rail0-hyper…"
echo "    Envio indexer  → http://localhost:8080"
echo "    Hono API       → http://localhost:${API_PORT:-3001}"
echo ""

# Hono API server — runs alongside Envio, shares the same DATABASE_URL
# --env-file loads .env directly into the node process (Node >= 20, no dotenv needed)
NODE_ENV="$NODE_ENV" pnpm tsx --env-file=.env src/api/index.ts &
API_PID=$!

# Clean up the API process when this script exits (Ctrl-C or Envio crash)
trap 'echo ""; echo "Stopping…"; kill "$API_PID" 2>/dev/null; wait "$API_PID" 2>/dev/null; exit 0' INT TERM EXIT

# Envio indexer (foreground — its output is the primary log stream)
NODE_ENV="$NODE_ENV" pnpm envio dev --config "$ENVIO_CONFIG"

# If envio exits cleanly, wait for the API process too
wait "$API_PID" 2>/dev/null || true
