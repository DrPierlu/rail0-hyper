{
  "name": "rail0-hyper",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bash bin/dev",
    "build": "tsup",
    "sync-start-blocks": "node bin/sync-start-blocks.mjs",
    "codegen": "envio codegen",
    "start": "concurrently \"envio start\" \"tsx src/api/index.ts\"",
    "api": "tsx src/api/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome lint ./src ./abis",
    "lint:fix": "biome lint --write ./src ./abis",
    "format": "biome format --write .",
    "check": "biome check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "concurrently": "^9.1.2",
    "envio": "^2.12.0",
    "generated": "workspace:*",
    "hono": "^4.12.23",
    "js-yaml": "^4.2.0",
    "pg": "^8.21.0",
    "viem": "^2.51.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.21",
    "@types/pg": "^8.20.0",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18.14"
  },
  "packageManager": "pnpm@9.0.0"
}
